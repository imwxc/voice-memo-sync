<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Voice Memo Sync - launchd Agent
  =================================
  Installation:
    1. Edit this file:
       - Replace /Users/YOUR_USERNAME with your actual home directory path
       - Verify PATH includes your node/nvm location if needed
    2. Copy to LaunchAgents:
       cp com.voice-memo-sync.plist ~/Library/LaunchAgents/
    3. Load the agent:
       launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.voice-memo-sync.plist

  Monitoring:
    launchctl print gui/$(id -u)/com.voice-memo-sync
    cat ~/.voice-memo-sync/data/voice-memos/launchd-stderr.log

  Uninstall:
    launchctl bootout gui/$(id -u) ~/Library/LaunchAgents/com.voice-memo-sync.plist
    rm ~/Library/LaunchAgents/com.voice-memo-sync.plist
-->
<plist version="1.0">
<dict>
    <!-- Service identifier -->
    <key>Label</key>
    <string>com.voice-memo-sync</string>

    <!-- Script to run -->
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/YOUR_USERNAME/.agents/skills/voice-memo-sync/scripts/auto-pipeline.sh</string>
    </array>

    <!-- Environment variables -->
    <key>EnvironmentVariables</key>
    <dict>
        <!-- PATH: add your nvm node path if needed -->
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
        <!-- Override workspace directory (optional) -->
        <key>VMS_WORKSPACE</key>
        <string>/Users/YOUR_USERNAME/.voice-memo-sync</string>
        <!-- Override output directory (optional) -->
        <key>VMS_OUTPUT_DIR</key>
        <string>/Users/YOUR_USERNAME/Documents</string>
        <!-- FunASR virtual env path (optional, defaults to ~/.funasr/venv) -->
        <!-- <key>VMS_FUNASR_ENV</key> -->
        <!-- <string>/Users/YOUR_USERNAME/.funasr/venv</string> -->
    </dict>

    <!-- Watch for new files in iCloud recordings directory -->
    <key>WatchPaths</key>
    <array>
        <string>/Users/YOUR_USERNAME/.voice-memo-sync/data/voice-memos/icloud</string>
    </array>

    <!-- Also run every 5 minutes as fallback polling -->
    <key>StartInterval</key>
    <integer>300</integer>

    <!-- Log output -->
    <key>StandardOutPath</key>
    <string>/Users/YOUR_USERNAME/.voice-memo-sync/data/voice-memos/launchd-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/YOUR_USERNAME/.voice-memo-sync/data/voice-memos/launchd-stderr.log</string>

    <!-- Auto-restart if it exits with an error -->
    <key>KeepAlive</key>
    <dict>
        <key>Crashed</key>
        <true/>
    </dict>

    <!-- Run when loaded (useful for catching up on missed recordings) -->
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
